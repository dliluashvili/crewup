model SocialNetworkLink {
  id       String @id @default(uuid()) @db.Uuid
  title    String @db.VarChar(255)
  position Int    @default(0) @db.SmallInt

  userSocialNetworkLinks UserSocialNetworkLink[]

  @@map("social_network_links")
}

model UserSocialNetworkLink {
  id                     String @id @default(uuid()) @db.Uuid
  userId                 String @db.Uuid @map("user_id")
  socialNetworkLinkId    String @db.Uuid @map("social_network_link_id")
  socialNetworkLinkTitle String @db.VarChar(255) @map("social_network_link_title")
  value                  String @db.VarChar(500)

  user              User              @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  socialNetworkLink SocialNetworkLink @relation(fields: [socialNetworkLinkId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@index([userId], map: "idx_user_social_link")
  @@index([socialNetworkLinkId], map: "idx_social_link_user")
  @@map("user_social_network_links")
}
