model ProfessionalLink {
  id       String @id @default(uuid()) @db.Uuid
  title    String @db.VarChar(255)
  position Int    @default(0) @db.SmallInt

  userProfessionalLinks UserProfessionalLink[]

  @@map("professional_links")
}

model UserProfessionalLink {
  id                    String @id @default(uuid()) @db.Uuid
  userId                String @db.Uuid
  professionalLinkId    String @db.Uuid
  professionalLinkTitle String @db.VarChar(255)
  value                 String @db.VarChar(500)

  user             User             @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  professionalLink ProfessionalLink @relation(fields: [professionalLinkId], references: [id], onUpdate: Cascade, onDelete: Cascade)

  @@index([userId], map: "idx_user_prof_link")
  @@index([professionalLinkId], map: "idx_prof_link_user")
  @@map("user_professional_links")
}
